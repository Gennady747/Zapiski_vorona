# ====================== ФУНКЦИИ ======================

def get_unique_item(items, recent_list, max_recent=20):
    """Берём элемент, который не использовали недавно"""
    available = [i for i in items if i not in recent_list]
    if not available:
        recent_list.clear()
        available = items
    
    item = random.choice(available)
    recent_list.append(item)
    if len(recent_list) > max_recent:
        recent_list.pop(0)
    
    return item

def generate_post():
    """Генерация поста — гарантированно рабочая, без AI"""
    global recent_starts, recent_cores, recent_ends
    
    # Получаем уникальные части
    start = get_unique_item(START_PHRASES, recent_starts)
    core = get_unique_item(CORE_MESSAGES, recent_cores)
    end = get_unique_item(END_PHRASES, recent_ends)
    
    # Выбираем эмодзи
    emoji = random.choice(START_EMOJIS)
    
    # Формируем пост
    post = f"{emoji} {start}\n\n{core}\n\n{end}"
    
    # Добавляем хэштеги/ссылки если нужно
    if ADD_HASHTAGS and HASHTAGS.strip():
        hashtags_block = f"\n{HASHTAGS}"
        post = (hashtags_block + "\n" + post) if HASHTAGS_POSITION == "up" else (post + hashtags_block)
    
    if ADD_LINKS and LINKS.strip():
        links_block = f"\n{LINKS}"
        post = (links_block + "\n" + post) if LINKS_POSITION == "up" else (post + links_block)
    
    return post.strip()

# ====================== ОТПРАВКА ======================

def send_photo(photo_url, caption):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendPhoto"
    try:
        r = requests.post(url, json={
            "chat_id": CHANNEL_ID,
            "photo": photo_url,
            "caption": caption[:1024],
            "parse_mode": "HTML"
        }, timeout=30)
        
        if not r.json().get("ok", False):
            url_text = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
            requests.post(url_text, json={
                "chat_id": CHANNEL_ID,
                "text": caption,
                "parse_mode": "HTML"
            })
        return True
    except Exception as e:
        print(f"   ❌ Ошибка: {e}")
        return False

def get_dark_image():
    topics = ["plague doctor", "black plague mask", "medieval doctor", "dark fantasy plague", "crow beak mask"]
    keyword = random.choice(topics)
    return f"https://loremflickr.com/800/600/{keyword}?lock={random.randint(1, 999999)}"

