EMOJIS = ["🎭", "👁️", "⏳", "💀", "🖤", "⚰️", "🔪", "🌑", "🩸", "🐦‍⬛"]

# ====================== ГЕНЕРАЦИЯ ======================

used_cores = set()

def get_random_unique(items, used_set, max_used=30):
    available = [x for x in items if x not in used_set]
    if not available or len(used_set) >= max_used:
        used_set.clear()
        available = items
    choice = random.choice(available)
    used_set.add(choice)
    return choice

def generate_post():
    global used_cores
    core  = get_random_unique(CORE_MESSAGES, used_cores)
    emoji = random.choice(EMOJIS)
    post = f"{emoji} {core}"
    return post.strip()

# ====================== ОТПРАВКА ======================

def send_photo(photo_url, caption):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendPhoto"
    try:
        r = requests.post(url, json={
            "chat_id": CHANNEL_ID,
            "photo": photo_url,
            "caption": caption[:1024],
            "parse_mode": "HTML"
        }, timeout=30)
        if not r.json().get("ok", False):
            url_text = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
            requests.post(url_text, json={
                "chat_id": CHANNEL_ID,
                "text": caption,
                "parse_mode": "HTML"
            })
        return True
    except Exception as e:
        print(f"   ❌ Ошибка отправки: {e}")
        return False

def get_dark_image():
    topics = ["plague doctor", "black plague mask", "medieval doctor", "dark fantasy plague", "crow beak mask"]
    keyword = random.choice(topics)
    return f"https://loremflickr.com/800/600/{keyword}?lock={random.randint(1, 999999)}"

