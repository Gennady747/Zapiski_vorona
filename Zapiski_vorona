def main():
    print("=" * 70)
    print("🤖 Бот «Записки Чумного Доктора» запущен")
    print(f"📝 Готовых комбинаций: {len(START_PHRASES)} × {len(CORE_MESSAGES)} × {len(END_PHRASES)}")
    if TEST_MODE == "on":
        print(f"ТЕСТОВЫЙ РЕЖИМ: посты каждые {TEST_INTERVAL_SECONDS} секунд")
    else:
        print("Обычный режим: 5 постов в день")
    print("=" * 70)

    count = 0
    last_send_time = time.time()
    last_post_hour = -1

    while True:
        now = datetime.now()

        if TEST_MODE == "on":
            if time.time() - last_send_time >= TEST_INTERVAL_SECONDS:
                last_send_time = time.time()
                count += 1
                print(f"\n📤 Тестовая записка #{count} | {now.strftime('%H:%M:%S')}")
                text = generate_post()
                print(f"   Длина: {len(text)} символов")
                print(f"   Превью: {text[:80]}...")
                if send_photo(get_dark_image(), text):
                    print("   ✅ Отправлено")
                else:
                    print("   ❌ Ошибка")
        else:
            hour = now.hour
            minute = now.minute
            schedule = {7: 30, 11: 0, 15: 30, 19: 0, 23: 0}
            
            if hour in schedule and minute == schedule[hour] and hour != last_post_hour:
                last_post_hour = hour
                count += 1

                print(f"\n📤 Записка #{count} | {now.strftime('%H:%M')}")
                text = generate_post()
                print(f"   Длина: {len(text)} символов")

                if send_photo(get_dark_image(), text):
                    print("   ✅ Отправлено успешно")
                else:
                    print("   ❌ Ошибка отправки")

                print(f"   ⏳ Следующая через несколько часов\n")

        if now.hour == 0 and now.minute == 0:
            last_post_hour = -1
            print("🌑 Новый день. Доктор на посту.")

        time.sleep(60)

if __name__ == "__main__":
    main()
