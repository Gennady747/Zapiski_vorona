    print("=" * 70)

    count = 0
    last_send_time = time.time()
    last_post_hour = -1

    while True:
        now = datetime.now()

        if TEST_MODE == "on":
            if time.time() - last_send_time >= TEST_INTERVAL_SECONDS:
                last_send_time = time.time()
                count += 1
                print(f"\n📤 Тест #{count} | {now.strftime('%H:%M:%S')}")
                text = generate_post()
                if send_photo(get_dark_image(), text):
                    print("   ✅ Отправлено")
                else:
                    print("   ❌ Ошибка")
        else:
            hour = now.hour
            minute = now.minute
            schedule = {7: 30, 11: 0, 15: 30, 19: 0, 23: 0}
            if hour in schedule and minute == schedule[hour] and hour != last_post_hour:
                last_post_hour = hour
                count += 1
                print(f"\n📤 Записка #{count} | {now.strftime('%H:%M')}")
                text = generate_post()
                if send_photo(get_dark_image(), text):
                    print("   ✅ Отправлено")
                else:
                    print("   ❌ Ошибка")

        if now.hour == 0 and now.minute == 0:
            last_post_hour = -1
            print("🌑 Новый день")

        time.sleep(60)

if __name__ == "__main__":
    main()
