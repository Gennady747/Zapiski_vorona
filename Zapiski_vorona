- Длина: начало 1-2 предложения, основной текст 3-5 предложений, конец 1 предложение."""

def generate_with_ollama(prompt, max_tokens=300):
    """Генерация текста через локальную модель Ollama"""
    try:
        response = requests.post(
            OLLAMA_URL,
            json={
                "model": MODEL_NAME,
                "prompt": prompt,
                "stream": False,
                "options": {
                    "temperature": 0.8,
                    "num_predict": max_tokens,
                    "top_p": 0.9,
                    "stop": ["\n\n\n", "Читатель:", "Доктор:"]
                }
            },
            timeout=60
        )
        
        if response.status_code == 200:
            result = response.json()
            text = result.get("response", "").strip()
            # Очистка от артефактов
            text = text.replace("**", "").replace("*", "").strip()
            # Убираем повторы фраз
            lines = text.split("\n")
            seen = set()
            unique_lines = []
            for line in lines:
                line = line.strip()
                if line and line not in seen and len(line) > 10:
                    seen.add(line)
                    unique_lines.append(line)
            return "\n".join(unique_lines)
        else:
            print(f"   ⚠️ Ошибка Ollama: {response.status_code}")
            return None
    except Exception as e:
        print(f"   ⚠️ Ошибка подключения к модели: {e}")
        return None

def generate_post():
    """Генерация поста через локальную модель"""
    
    # Выбираем случайные темы для структуры
    start_theme = random.choice(START_THEMES)
    core_theme = random.choice(CORE_THEMES)
    end_theme = random.choice(END_THEMES)
    
    # Промпт для генерации начальной фразы
    prompt_start = f"""{CHARACTER_DESCRIPTION}

Задача: напиши НАЧАЛЬНУЮ фразу поста.
Стиль начала: {start_theme}
Требования:
- 1-2 коротких предложения
- Обращение к читателю напрямую ("ты", "больной")
- Холодный, беспощадный тон
- Без воды, только острые слова

Начало:"""

    # Промпт для основного текста
    prompt_core = f"""{CHARACTER_DESCRIPTION}

Начало поста: [СТАРТ]

Задача: напиши ОСНОВНОЙ текст поста.
Тема: {core_theme}
Требования:
- 3-5 предложений
- Развивай тему остро и метко
- Медицинские метафоры приветствуются
- Без повторов и банальностей
- Каждое предложение — удар

Основной текст:"""

    # Промпт для концовки
    prompt_end = f"""{CHARACTER_DESCRIPTION}

Начало: [СТАРТ]
Основной текст: [ЯДРО]

Задача: напиши КОНЦОВКУ поста.
Стиль концовки: {end_theme}
Требования:
- 1 короткое предложение (можно 2 если нужно)
- Точка. Не многоточие.
- Оставляет читателя с ощущением выбора или угрозы

Концовка:"""

    # Генерируем части
    print("   🧠 Генерация начала...")
    start = generate_with_ollama(prompt_start, max_tokens=100)
    
    print("   🧠 Генерация основного текста...")
    # Подставляем начало в промпт основного текста
    prompt_core_filled = prompt_core.replace("[СТАРТ]", start or "Чумной Доктор шепчет:")
    core = generate_with_ollama(prompt_core_filled, max_tokens=250)
    
    print("   🧠 Генерация концовки...")
    # Подставляем части в промпт концовки
    prompt_end_filled = prompt_end.replace("[СТАРТ]", start or "").replace("[ЯДРО]", core or "")
    end = generate_with_ollama(prompt_end_filled, max_tokens=80)
    
    # Если модель не ответила — fallback на заготовки
    if not start:
        start = random.choice([
            "Чумной Доктор шепчет тебе в ухо:",
            "Слушай внимательно, больной.",
            "Я вижу тебя сквозь маску."
        ])
    if not core:
        core = random.choice([
            "Ты строишь свою жизнь из оправданий. Получается хлипко. Однажды всё рухнет.",
            "Твоя лень — это не отдых. Это тихая смерть. Медленная, комфортная, с улыбкой на лице."
        ])
    if not end:
        end = random.choice([
            "Я уже жду.",
            "Песок сыплется.",
            "Твой ход, больной."
        ])
    
    # Собираем пост
    post = f"{start}\n\n{core}\n\n{end}"
    
    # Добавляем хэштеги/ссылки если нужно
    if ADD_HASHTAGS and HASHTAGS.strip():
        hashtags_block = f"\n{HASHTAGS}"
        post = (hashtags_block + "\n" + post) if HASHTAGS_POSITION == "up" else (post + hashtags_block)
    
    if ADD_LINKS and LINKS.strip():
        links_block = f"\n{LINKS}"
        post = (links_block + "\n" + post) if LINKS_POSITION == "up" else (post + links_block)
    
    return post.strip()

